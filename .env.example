# Copy this to .env and fill in your values
# GoPlus Security API key (optional — free tier works without one, but key removes stricter rate limits)
GOPLUS_API_KEY=

# Etherscan API key — required only for P2 /v1/tax-report (free signup at https://etherscan.io/apis)
ETHERSCAN_API_KEY=

# Server port (Render injects $PORT automatically)
PORT=3000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Rate limiting: requests per minute per IP (default 60)
RATE_LIMIT_RPM=60

# Cache TTL in milliseconds (default 60000 = 60s)
CACHE_TTL_MS=60000
